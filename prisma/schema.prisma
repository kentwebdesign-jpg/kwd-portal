// Kent Web Design portal — database schema.
// One row per completed onboarding brief. The full set of answers is stored
// as JSON in `data`; a few key fields are pulled out as columns so we can list
// and search submissions without parsing the JSON every time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id           String   @id @default(cuid())
  userId       String?  @unique // Clerk user id of the client who owns this brief
  status       String   @default("new") // new | in_progress | built | archived
  businessName String?
  contactName  String?
  contactEmail String?
  data         Json // the full collectText() payload from the form
  buildStatus  String? // null = not built | building | ready | error
  buildStage   String? // human-readable progress while building
  buildSiteUrl String? // the provisioned WordPress site URL
  buildData    Json? // { wp_username, wp_password, task_id, ... } or { error }
  builtAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChangeRequest {
  id          String   @id @default(cuid())
  userId      String // Clerk user id of the client who raised it
  clientEmail String? // captured at creation for easy display in admin
  title       String
  details     String
  status      String   @default("open") // open | in_progress | done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

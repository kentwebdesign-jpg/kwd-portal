# kwd-portal environment variables
# Copy this file to `.env` and fill in the real values (get them from
# Railway → kwd-portal service → Variables). Never commit `.env`.

# --- Database (Railway Postgres) ---
# In Railway this is a reference: ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# --- Auth (Clerk — clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # pk_... (public, baked in at build time)
CLERK_SECRET_KEY=                    # sk_... (secret)

# Comma-separated emails that get the ADMIN view. Everyone else is a client.
ADMIN_EMAILS=you@kentwebdesign.com

# --- File storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kwd-portal-uploads

# --- Site provisioning (InstaWP — app.instawp.io, Read/Write API token) ---
INSTAWP_API_TOKEN=

# --- AI design (Anthropic — console.anthropic.com) ---
# Optional: if unset, the build falls back to a basic theme instead of AI design.
ANTHROPIC_API_KEY=

# --- Admin email notifications (Mailgun) ---
# Optional: if unset, build-complete emails are skipped (build still works).
MAILGUN_API_KEY=
MAILGUN_DOMAIN=          # your Mailgun sending domain
NOTIFY_EMAIL=hello@kentwebdesign.com   # where build notifications go
# MAILGUN_BASE=https://api.mailgun.net  # only if your Mailgun account is US (default is EU)
# MAILGUN_FROM=Kent Web Design Portal <noreply@your-domain>  # optional override

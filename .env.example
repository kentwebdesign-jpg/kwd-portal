# kwd-portal environment variables
# Copy this file to `.env` and fill in the real values (get them from
# Railway → kwd-portal service → Variables). Never commit `.env`.

# --- Database (Railway Postgres) ---
# In Railway this is a reference: ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# --- Auth (Clerk — clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # pk_... (public, baked in at build time)
CLERK_SECRET_KEY=                    # sk_... (secret)

# Comma-separated emails that get the ADMIN view. Everyone else is a client.
ADMIN_EMAILS=you@kentwebdesign.com

# --- File storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kwd-portal-uploads

# --- Site provisioning (InstaWP — app.instawp.io, Read/Write API token) ---
INSTAWP_API_TOKEN=

# --- AI copy (Anthropic — console.anthropic.com) ---
# Optional: if unset, the build falls back to raw brief text instead of AI copy.
ANTHROPIC_API_KEY=
